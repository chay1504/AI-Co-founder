{
  "name": "ai-cofounder-backend",
  "version": "1.0.0",
  "description": "AI Co-Founder MVP Backend Implementation",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "npx prisma generate --skip-engine-check && tsc --skipLibCheck",
    "test": "jest --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --forceExit",
    "test:single": "jest --testNamePattern",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate": "npx prisma migrate dev",
    "prisma:studio": "npx prisma studio"
  },
  "keywords": [
    "ai",
    "backend",
    "express",
    "prisma",
    "agenda"
  ],
  "author": "Anti-Gravity",
  "license": "MIT",
  "dependencies": {
    "@clerk/clerk-sdk-node": "^4.12.21",
    "@prisma/client": "^5.11.0",
    "@slack/web-api": "^7.0.2",
    "agenda": "^5.0.0",
    "axios": "^1.6.8",
    "cors": "^2.8.5",
    "decimal.js": "^10.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.11.30",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "prisma": "^5.11.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.3"
  }
}
