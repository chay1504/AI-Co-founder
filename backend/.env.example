# Server Config
PORT=3001
NODE_ENV=production

# Database (PostgreSQL - set in Render dashboard for production)
DATABASE_URL=postgresql://placeholder

# Auth (Clerk) - Get from https://dashboard.clerk.com
CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_key_here

# Slack Integration - Get from https://api.slack.com/apps
SLACK_CLIENT_ID=your_slack_client_id
SLACK_CLIENT_SECRET=your_slack_client_secret
SLACK_SIGNING_SECRET=your_slack_signing_secret

# GitHub Integration - Get from https://github.com/settings/developers
GITHUB_APP_CLIENT_ID=your_github_client_id
GITHUB_APP_CLIENT_SECRET=your_github_client_secret

# Logging
LOG_LEVEL=info
